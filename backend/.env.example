APP_NAME=ThermoFisher Sales Platform
CORS_ORIGINS=*

# LLM config (optional)
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Data
PRODUCT_DATA_PATH=

# GraphRAG (optional) - run docker-compose to start neo4j + graph_service
GRAPH_RAG_ENABLED=false
GRAPH_SERVICE_URL=http://127.0.0.1:3000
